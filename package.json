{
    "author": {
        "name": "Jose Manuel Gomez Perez",
        "url": "https://github.com/jmgomezdev"
    },
    "bin": {
        "ghcopilot-hub": "./tooling/cli/src/bin.js"
    },
    "bugs": {
        "url": "https://github.com/jmgomezdev/ghcopilot-hub/issues"
    },
    "dependencies": {
        "@clack/prompts": "^1.2.0",
        "yaml": "^2.8.1"
    },
    "description": "Centralized GitHub Copilot hub with shared agents, skills, packs, and a sync CLI for VS Code repositories.",
    "devDependencies": {
        "@eslint/js": "^9.22.0",
        "eslint": "^9.22.0",
        "globals": "^16.0.0",
        "prettier": "^3.5.3"
    },
    "engines": {
        "bun": ">=1.0.0",
        "node": ">=20.0.0"
    },
    "files": [
        "hub",
        "tooling/cli/src",
        "README.md"
    ],
    "homepage": "https://github.com/jmgomezdev/ghcopilot-hub#readme",
    "keywords": [
        "copilot",
        "github-copilot",
        "vscode",
        "cli",
        "bun",
        "agents",
        "skills"
    ],
    "license": "MIT",
    "name": "ghcopilot-hub",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jmgomezdev/ghcopilot-hub.git"
    },
    "scripts": {
        "cli": "node ./tooling/cli/src/bin.js",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "pack:check": "npm pack --dry-run",
        "prepublishOnly": "npm run validate:hub && npm test && npm run pack:check",
        "test": "node --test tooling/cli/test/integration.test.js tooling/cli/test/unit.test.js",
        "validate:hub": "node ./tooling/cli/src/bin.js doctor --hub-only"
    },
    "type": "module",
    "version": "2.1.0"
}